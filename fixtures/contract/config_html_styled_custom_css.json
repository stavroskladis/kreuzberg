{
	"id": "config_html_styled_custom_css",
	"description": "HTML output with inline user CSS string is embedded verbatim in the style block",
	"tags": ["contract", "output_format", "html_styled"],
	"document": {
		"path": "pdf/fake_memo.pdf"
	},
	"extraction": {
		"method": "sync",
		"input_type": "file",
		"config": {
			"output_format": "html",
			"html_output": {
				"theme": "unstyled",
				"css": ".kb-p { color: red; }",
				"embed_css": true
			}
		}
	},
	"assertions": {
		"output_format_is": "html",
		"content_contains_all": [".kb-p { color: red; }", "kb-doc"]
	},
	"skip": {}
}
